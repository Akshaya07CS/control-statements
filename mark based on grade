#include <stdio.h>
int main()
{
        int marks;
        printf("Enter the marks:");
        scanf("%d",&marks);
        if (marks >= 91 && marks <= 100)
        {
        printf ("Grade:o");
        }
        else if (marks >= 81 && marks <= 90)
        {
        printf ("Grade:a+");
        }
        else if (marks >= 71 && marks <= 80)
        {
        printf ("Grade:A");
        }
        else if (marks >= 61 && marks <= 70)
        {
        printf("Grade:B+");
        }
        else if (marks >= 50 && marks <=60)
        {
        printf("Grade:B");
        }
        else if (marks>=1 &&  marks < 50)
        {
        printf("Grade:RA");
        }
        else
        {
        printf("Invalid mark");
        }
        return 0;
}

